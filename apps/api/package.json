{
  "name": "@avelap/api",
  "version": "1.1.0",
  "private": true,
  "description": "avelap.hu backend (Strapi)",
  "license": "MIT",
  "author": {
    "name": "atistrcsn"
  },
  "scripts": {
    "build": "strapi build",
    "cfgsync": "config-sync",
    "develop": "strapi develop",
    "export": "pnpm strapi export --no-encrypt -f ../seed-data",
    "seed": "pnpm strapi import -f ../seed-data.tar.gz",
    "start": "strapi start",
    "strapi": "strapi"
  },
  "dependencies": {
    "@sklinet/strapi-plugin-video-field": "^1.1.2",
    "@strapi-community/plugin-seo": "^2.0.9",
    "@strapi/plugin-documentation": "5.40.0",
    "@strapi/plugin-users-permissions": "5.40.0",
    "@strapi/provider-upload-aws-s3": "^5.31.3",
    "@strapi/strapi": "5.40.0",
    "@yunusemrejs/drag-drop-content-types-strapi5": "^1.0.11",
    "pg": "^8.16.3",
    "pg-connection-string": "^2.9.1",
    "react": "~18.3.1",
    "react-dom": "~18.3.1",
    "react-router-dom": "^6.0.0",
    "strapi-plugin-config-sync": "^3.1.2",
    "styled-components": "^6.1.19"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/plugin-transform-runtime": "^7.25.0",
    "@babel/preset-react": "^7.25.0",
    "@strapi/typescript-utils": "^5.32.0",
    "@types/node": "^22.19.3",
    "babel-loader": "^9.2.0",
    "better-sqlite3": "12.5.0",
    "vite": "^7.2.7"
  },
  "engines": {
    "node": ">=20"
  },
  "strapi": {
    "uuid": "d5f5c158-e89f-4505-847f-4cefe7ccd649",
    "telemetryDisabled": true
  },
  "pnpm": {
    "overrides": {
      "react": "~18.3.1",
      "react-dom": "~18.3.1"
    }
  },
  "nx": {
    "targets": {
      "build": {
        "executor": "@nx/js:tsc",
        "options": {
          "buildTarget": "api:build",
          "outputPath": "dist/apps/api",
          "main": "apps/api/dist/index.js",
          "tsConfig": "apps/api/tsconfig.json"
        },
        "outputs": [
          "{workspaceRoot}/dist/apps/api"
        ],
        "cache": true
      },
      "lint": {
        "executor": "@nx/eslint:lint",
        "options": {
          "lintFilePatterns": [
            "apps/api/**/*.{ts,tsx,js,jsx}"
          ]
        },
        "cache": true
      }
    },
    "tags": []
  }
}
